{
  "name": "tritha-browser",
  "productName": "Tritha",
  "version": "1.0.2",
  "description": "Dedicated browser for Tritha panel",
  "author": {
    "name": "Tritha",
    "email": "support@tritha.cloud"
  },
  "homepage": "https://panel.tritha.cloud",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "cloud.tritha.browser",
    "productName": "Tritha",
    "asar": true,
    "asarUnpack": [
      "assets/**"
    ],
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "velensetechnologies",
      "repo": "Tritha_webBrowser"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "settings-preload.js",
      "overlay-preload.js",
      "settings.html",
      "loading.html",
      "error.html",
      "overlay.html",
      "assets/**",
      "!**/node_modules/.cache/**",
      "!**/*.map",
      "!**/*.md"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/tritha-icon-512.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tritha-icon-512.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tritha-icon-512.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": true
    },
    "electronDownload": {
      "cache": ".electron-cache"
    }
  }
}
